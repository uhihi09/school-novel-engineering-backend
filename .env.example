# ── EquiScope backend configuration ────────────────────────────────────────────
# Copy to `.env` and fill in. Every value has a safe local default, so the backend
# runs on SQLite + high-quality Gemini mock fallbacks with an empty .env.

# ── Gemini / Vertex AI ──────────────────────────────────────────────────────────
# Google AI Studio API key. Leave blank to run on mock fallbacks.
GEMINI_API_KEY=

# Set true to route Gemini through Vertex AI instead of an API key.
# Requires GOOGLE_APPLICATION_CREDENTIALS (service-account JSON path) + GCP_PROJECT_ID.
USE_VERTEX_AI=false
GCP_PROJECT_ID=
GCP_LOCATION=asia-northeast3
# Path to your GCP service-account key JSON (read by the Google SDK, not by the app).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Model ids (override to pin different Gemini versions).
GEMINI_FLASH_MODEL=gemini-3.5-flash
GEMINI_PRO_MODEL=gemini-3.1-pro

# ── Storage ─────────────────────────────────────────────────────────────────────
# GCS bucket for uploaded citizen-report media (F-2 / F-6).
GCS_BUCKET=equiscope-reports

# ── Database ────────────────────────────────────────────────────────────────────
# Leave DATABASE_URL blank/commented to use the local SQLite default.
#
# Cloud SQL for PostgreSQL 18 — instance: iceu-578:asia-northeast3:school-hackathon-db
# Set DB_PASSWORD (and change the user/db name if not the 'postgres' defaults).
# After setting this, create the tables with:  python scripts/init_db.py
#
# Option A — direct Public IP (add your client IP under the instance's
#            Connections > Networking > "Authorized networks" first):
# DATABASE_URL=postgresql+pg8000://postgres:DB_PASSWORD@34.64.248.130:5432/postgres
#
# Option B — Cloud SQL Auth Proxy (no authorized networks needed; first run:
#   cloud-sql-proxy iceu-578:asia-northeast3:school-hackathon-db --port 5432 ):
# DATABASE_URL=postgresql+pg8000://postgres:DB_PASSWORD@127.0.0.1:5432/postgres

# ── Auth (JWT) ──────────────────────────────────────────────────────────────────
# CHANGE THIS in any non-local environment. Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME__run_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
